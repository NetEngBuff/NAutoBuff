# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/

# ── NAutoBuff runtime data ──────────────────────────────────────────────────────
# Hosts inventory — contains live credentials, rotated by password_update.service
NSOT/IPAM/hosts.csv

# User database — hashed passwords, managed at runtime
NSOT/IPAM/users.db

# SNMP polling output — regenerated every 10s by ipam.service
NSOT/IPAM/ipam_output.csv

# Generated device configs — output of config_Gen.py
NSOT/configs/*
!NSOT/configs/.gitkeep

# Golden configs — captured running configs, change with every backup
NSOT/golden_configs/*
!NSOT/golden_configs/.gitkeep
NSOT/golden-configs/

# Topology files generated by containerlab at runtime
clab-*/
NSOT/topology/
pilot-config/clab-*/
pilot-config/.*.bak

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
NSOT/logs/*
!NSOT/logs/.gitkeep

# ── ML training artefacts ─────────────────────────────────────────────────────
NSOT/machine_learning/models/*.pkl
NSOT/machine_learning/models/*.joblib
NSOT/machine_learning/models/*.h5

# ── OS / editor junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── Runtime-modified config files ─────────────────────────────────────────────
# Updated automatically by update_gnmic_yaml_from_hosts() when devices change
gnmic-stream.yaml

# Rewritten by build/deploy topology operations
pilot-config/topo.yml

# ── Secrets / keys ────────────────────────────────────────────────────────────
influxdata-archive.key
NSOT/misc/ngrok_config.yml
*.pem
*.key
pilot-config/.jenkins_creds

# ── Claude Code ───────────────────────────────────────────────────────────────
CLAUDE.md
